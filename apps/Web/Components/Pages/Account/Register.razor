@page "/register"
@using System.ComponentModel.DataAnnotations
@inject Database.Data DataService
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card card shadow-sm">
        <div class="card-body">
            <div class="logo mb-3">
                <img src="favicon.png" alt="Logo" />
            </div>

            <h4 class="card-title mb-3">Create account</h4>

            <EditForm Model="credentials" FormName="registerForm" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" @bind-Value="credentials.Username" autofocus />
                    <ValidationMessage For="@(() => credentials.Username)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText class="form-control" @bind-Value="credentials.Password" type="password" />
                    <ValidationMessage For="@(() => credentials.Password)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm password</label>
                    <InputText class="form-control" @bind-Value="credentials.ConfirmPassword" type="password" />
                    <ValidationMessage For="@(() => credentials.ConfirmPassword)" />
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger" role="alert">@error</div>
                }

                <button class="btn btn-primary w-100" type="submit" disabled="@isBusy" aria-busy="@isBusy">
                    @if (isBusy)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span class="ms-2">Creating account...</span>
                    }
                    else
                    {
                        <span>Register</span>
                    }
                </button>
            </EditForm>

            <div class="mt-3 text-center">
                <a href="/login" class="text-muted small">Already have an account? Sign in</a>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public RegisterCredentials credentials { get; set; } = new();

    private bool isBusy;
    private string? error;

    private async Task HandleRegister()
    {
        error = null;
        isBusy = true;

        try
        {
            var enteredUser = credentials.Username?.Trim() ?? string.Empty;
            var enteredPass = credentials.Password ?? string.Empty;
            var confirmPass = credentials.ConfirmPassword ?? string.Empty;

            if (string.IsNullOrWhiteSpace(enteredUser))
            {
                error = "Username is required.";
                return;
            }

            if (enteredPass.Length < 4)
            {
                error = "Password must be at least 4 characters.";
                return;
            }

            if (!string.Equals(enteredPass, confirmPass, StringComparison.Ordinal))
            {
                error = "Passwords do not match.";
                return;
            }

            var existingUser = DataService.GetUsers()
                .FirstOrDefault(u => string.Equals(u.Username?.Trim(), enteredUser, StringComparison.OrdinalIgnoreCase));

            if (existingUser is not null)
            {
                error = "That username is already taken.";
                return;
            }

            var created = DataService.CreateUser(enteredUser, enteredPass);
            if (!created)
            {
                error = "Unable to create account.";
                return;
            }

            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            error = "Registration failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    public class RegisterCredentials
    {
        [Required]
        public string Username { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        [Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}