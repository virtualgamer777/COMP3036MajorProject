@page "/admin/edit/{id}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@using Web.Components.Shared
@inject NavigationManager Navigation
@rendermode InteractiveServer


<ListingModifier ListingId="@parsedId" OnSuccess="@((UInt64? id) => HandleSuccess(id))" />

@code {
    [Parameter]
    public string id { get; set; } = string.Empty;

    private UInt64? parsedId;

    //get id for post
    protected override void OnInitialized()
    {
        if (UInt64.TryParse(id, out var listingId))
        {
            parsedId = listingId;
        }
    }

    //go back to dashboard after editing page
    private async Task HandleSuccess(UInt64? newListingId)
    {
        Navigation.NavigateTo("/admin/listingdashboard");
    }
}