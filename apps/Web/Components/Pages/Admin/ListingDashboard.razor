@page "/admin/listingdashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Components.Shared
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject Database.Data data
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Listing Dashboard</PageTitle>

@if(isLoading)
{
	<div>Loading…</div>

}
else
{
	<h1 class="major-heading">Listings Dashboard</h1>
	<div class="mb-3">
		<button class="btn btn-success mb-2" @onclick="CreateListing">Create Listing</button>

		<input class="form-control" placeholder="Search listings..." @bind="searchTerm" @bind:event="oninput" />
	</div>

	<ListingsAdminComponent Listings="FilteredListings" />
}


@code {
    private Database.Data.Listing[] Listings = Array.Empty<Database.Data.Listing>();
    private string searchTerm = string.Empty;
	private bool isLoading = true;


	//private UInt64? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        @* var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true || !user.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }
		
        var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (UInt64.TryParse(userIdClaim, out var userId))
        {
            currentUserId = userId;
        } *@
		Listings = data.GetListings();
		isLoading = false;

    }

    private IEnumerable<Database.Data.Listing> FilteredListings =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? Listings
            : Listings.Where(l =>
                (l.ItemName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
                || (l.ItemDescription?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
            );
	
	private void CreateListing()
    {
        Navigation.NavigateTo("/admin/createlisting");
    }
}
