@page "/"
@using Web.Components.Shared
@rendermode InteractiveServer
@inject Database.Data data

<PageTitle>Listings</PageTitle>

<h1 class="major-heading">Listings</h1>

<div class="mb-3">
    <input class="form-control" placeholder="Search listings..." @bind="searchTerm" @bind:event="oninput" />
</div>

<ListingsComponent Listings="FilteredListings" />

@code {
    private Database.Data.Listing[] Listings = Array.Empty<Database.Data.Listing>();
    private string searchTerm = string.Empty;


    protected override void OnInitialized()
    {
        Listings = data.GetListings();
    }
    private IEnumerable<Database.Data.Listing> FilteredListings =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? Listings
            : Listings.Where(l =>
                (l.ItemName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
                || (l.ItemDescription?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
            );
}
